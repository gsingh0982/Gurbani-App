@model Gurbani.Models.AngViewModel
@{
    ViewData["Title"] = $"Ang {Model?.CurrentAng} — Guru Granth Sahib";
}

<div class="container mt-3 px-3">

    <form asp-controller="Gurbani" asp-action="Read" method="get" class="d-flex gap-2 mb-4">
        <input type="number" name="ang" class="form-control ang-input"
               placeholder="Go to Ang (1–1430)"
               min="1" max="1430"
               value="@Model?.CurrentAng" />
        <button type="submit" class="btn btn-gold px-3">Go</button>
    </form>

    @if (ViewBag.Error != null)
    {
        <div class="alert alert-danger">@ViewBag.Error</div>
    }

    @if (Model != null)
    {
        <div class="ang-header text-center mb-4">
            <span class="badge bg-gold fs-6">Ang @Model.CurrentAng</span>
        </div>

        @foreach (var verse in Model.Verses)
        {
            <div class="verse-card mb-4">
                <p class="gurmukhi-text">@verse.Gurmukhi</p>
                @if (!string.IsNullOrEmpty(verse.Transliteration))
                {
                    <p class="transliteration">@verse.Transliteration</p>
                }
                @if (!string.IsNullOrEmpty(verse.Translation))
                {
                    <p class="translation">@verse.Translation</p>
                }
            </div>
        }

        <div class="d-flex justify-content-between mt-4 mb-2">
            @if (Model.CurrentAng > 1)
            {
                <a asp-controller="Gurbani" asp-action="Read" asp-route-ang="@(Model.CurrentAng - 1)"
                   class="btn btn-outline-gold">&#8592; Ang @(Model.CurrentAng - 1)</a>
            }
            else { <span></span> }

            @if (Model.CurrentAng < 1430)
            {
                <a asp-controller="Gurbani" asp-action="Read" asp-route-ang="@(Model.CurrentAng + 1)"
                   class="btn btn-outline-gold">Ang @(Model.CurrentAng + 1) &#8594;</a>
            }
        </div>
    }
</div>
